# Rename this file to .env and fill in your values
# Never commit .env to git

FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR KEY HERE\n-----END PRIVATE KEY-----\n"

TRONGRID_API_KEY=your-trongrid-api-key

# Make this a long random string
CRON_SECRET=change-this-to-something-random-123

# Optional: your HD wallet mnemonic (12 words) for real USDT addresses
# WALLET_MNEMONIC=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12
